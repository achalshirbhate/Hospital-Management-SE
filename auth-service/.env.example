# ── PostgreSQL (Supabase) ──
DB_URL=jdbc:postgresql://aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=YOUR_DB_PASSWORD

# ── JWT ──
# Generate a strong secret: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRATION_MS=86400000

# ── Email (Gmail App Password) ──
MAIL_USERNAME=your@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ── CORS (comma-separated list of allowed frontend origins) ──
CORS_ALLOWED_ORIGINS=https://your-admin-panel.vercel.app,http://localhost:3000

# ── Server Port ──
PORT=8081
